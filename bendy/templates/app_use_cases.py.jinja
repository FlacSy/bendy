class Get{{ domain_name|capitalize }}UseCase:
    def __init__(self, uow: {{ domain_name|capitalize }}UnitOfWork) -> None:
        self._uow = uow

    async def execute(self, id: UUID) -> {{ domain_name|capitalize }}Response:
        async with self._uow:
