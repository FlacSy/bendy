{%- if 'update' in use_cases %}


class Update{{ domain_name|capitalize }}UseCase:
    def __init__(self, uow: {{ domain_name|capitalize }}UnitOfWork) -> None:
        self._uow = uow

    async def execute(self, id: UUID, data: {{ domain_name|capitalize }}Update) -> {{ domain_name|capitalize }}Response:
        async with self._uow:
            entity = await self._uow.{{ domain_name }}s.get_by_id(id)
            if entity is None:
                raise ValueError(f"{{ domain_name|capitalize }} {id} not found")
            updated = replace(entity, **data.model_dump(exclude_unset=True))
            await self._uow.{{ domain_name }}s.save(updated)
            await self._uow.commit()
            return {{ domain_name|capitalize }}Response.model_validate(updated)
{%- endif %}
